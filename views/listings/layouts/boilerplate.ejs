<body>
    <%- include("../includes/navbar.ejs") %>
    
    <div class="container">
    <%- include("../includes/flash.ejs") %>

        <%- body %>
    </div>
    
    <%- include("../includes/footer.ejs") %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    <script src="/js/script.js"></script>

    <!-- ChatBot HTML -->
     <!-- 💬 Chatbot Button -->
<!-- <div id="chat-toggle" style="position:fixed; bottom:20px; right:20px; cursor:pointer; background:#fe424d; color:white; padding:10px 15px; border-radius:50px;">
  Chat 💬
</div>

<!-- 💬 Chatbox -->
<div id="chatbox" style="display:none; position:fixed; bottom:80px; right:20px; width:300px; height:400px; background:white; border-radius:10px; box-shadow:0 0 10px rgba(0,0,0,0.2); padding:10px; overflow:hidden;">

  <div id="messages" style="height:300px; overflow-y:auto; font-size:14px;"></div>

  <input id="msg" type="text" placeholder="Ask something..." style="width:70%;" />
  <button onclick="sendMsg()">Send</button>

</div>
<!-- JS Part of ChatBot -->
<script>
const toggleBtn = document.getElementById("chat-toggle");
const chatbox = document.getElementById("chatbox");

toggleBtn.addEventListener("click", () => {
  chatbox.style.display = chatbox.style.display === "none" ? "block" : "none";
});

async function sendMsg() {
  const input = document.getElementById("msg");
  const msg = input.value;

  if (!msg) return;

  const messages = document.getElementById("messages");

  // user message
  messages.innerHTML += `<p><b>You:</b> ${msg}</p>`;

  input.value = "";

  const res = await fetch("/chat", {
    method: "POST",
    headers: {
      "Content-Type": "application/json"
    },
    body: JSON.stringify({ message: msg })
  });

  const data = await res.json();

  // bot reply
  messages.innerHTML += `<p><b>Bot:</b> ${data.reply}</p>`;

  messages.scrollTop = messages.scrollHeight;
}
</script>
</body>
</html>