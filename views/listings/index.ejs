<% layout("/listings/layouts/boilerplate") %>  
<style>
   #filters {
      display: flex;
      flex-wrap: nowrap;
      align-items: center;
      overflow-x: visible;
   }

   .filter {
      text-align: center;
      margin-right: 2rem;
      opacity: 0.7;
      flex-shrink: 0;
   }

   .filter:hover {
      opacity: 1;
      cursor: pointer;
   }

   .filter p {
      font-size: 0.8rem;
      margin-bottom: 0;
   }

   .tax-info {
      display: none;
   }

   .tax-toggle {
      border: 1px solid black;
      border-radius: 1rem;
      height: 3.25rem;
      padding: 1rem;
      margin-left: auto;
      display: flex;
      align-items: center;
      flex-shrink: 0;
      white-space: nowrap;
   }

   .listing-link {
      text-decoration: none;
      color: inherit;
   }

   .listing-card {
      border: none;
      transition: transform 0.25s ease, box-shadow 0.25s ease;
   }

   .listing-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 8px 24px rgba(0,0,0,0.12);
   }

   .wishlist-btn {
      position: absolute;
      top: 12px;
      right: 12px;
      background: rgba(255,255,255,0.85);
      border: none;
      border-radius: 50%;
      width: 34px;
      height: 34px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      z-index: 10;
   }

   .wishlist-btn:hover {
      background: white;
   }

   .wishlist-btn svg {
      width: 17px;
      height: 17px;
   }

   .wishlist-btn.liked svg {
      fill: #fe424d;
      stroke: #fe424d;
   }

   .card-rating {
      float: right;
      font-size: 0.85rem;
      font-weight: 500;
   }
</style>

<div id="filters">

   <a href="/listings?category=trending" class="filter text-decoration-none text-dark">
      <div><i class="fa-solid fa-fire"></i></div>
      <p>Trending</p>
   </a>

   <a href="/listings?category=rooms" class="filter text-decoration-none text-dark">
      <div><i class="fa-solid fa-bed"></i></div>
      <p>Rooms</p>
   </a>

   <a href="/listings?category=iconic" class="filter text-decoration-none text-dark">
      <div><i class="fa-solid fa-mountain-city"></i></div>
      <p>Iconic Cities</p>
   </a>

   <a href="/listings?category=mountains" class="filter text-decoration-none text-dark">
      <div><i class="fa-solid fa-mountain"></i></div>
      <p>Mountains</p>
   </a>

   <a href="/listings?category=castles" class="filter text-decoration-none text-dark">
      <div><i class="fa-brands fa-fort-awesome"></i></div>
      <p>Castles</p>
   </a>

   <a href="/listings?category=pools" class="filter text-decoration-none text-dark">
      <div><i class="fa-solid fa-person-swimming"></i></div>
      <p>Amazing Pools</p>
   </a>

   <a href="/listings?category=camping" class="filter text-decoration-none text-dark">
      <div><i class="fa-solid fa-campground"></i></div>
      <p>Camping</p>
   </a>

   <a href="/listings?category=farms" class="filter text-decoration-none text-dark">
      <div><i class="fa-solid fa-cow"></i></div>
      <p>Farms</p>
   </a>

   <a href="/listings?category=arctic" class="filter text-decoration-none text-dark">
      <div><i class="fa-solid fa-snowflake"></i></div>
      <p>Arctic</p>
   </a>

   <a href="/listings?category=domes" class="filter text-decoration-none text-dark">
      <div><i class="fa-solid fa-landmark-dome"></i></div>
      <p>Domes</p>
   </a>

   <a href="/listings?category=boats" class="filter text-decoration-none text-dark">
      <div><i class="fa-solid fa-ship"></i></div>
      <p>Boats</p>
   </a>

   <!-- tax toggle -->
   <div class="tax-toggle">
      <div class="form-check-reverse form-switch">
         <input 
            class="form-check-input" 
            type="checkbox" 
            role="switch" 
            id="flexSwitchCheckDefault">
         <label class="form-check-label" for="flexSwitchCheckDefault">
            Display total after taxes
         </label>
      </div>
   </div>

</div>
   
<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">

   <% if(allListings.length === 0) { %>
      <div class="text-center mt-5 w-100">
         <h3>No Listings Found 😔</h3>
         <p>Try searching something else or explore other categories.</p>
         <a href="/listings" class="btn btn-dark mt-2">Explore All</a>
      </div>
   <% } else { %>
      <% for(let listing of allListings) { %>
         <a href="/listings/<%= listing._id %>" class="listing-link">
            <div class="card col listing-card mb-3">
               <div class="position-relative">
                  <img 
                     src="<%= listing.image.url %>" 
                     class="card-img-top" 
                     alt="listing_image" 
                     style="height: 20rem; object-fit: cover;"
                  />
                  <button class="wishlist-btn" onclick="event.preventDefault(); this.classList.toggle('liked');">
                     <svg viewBox="0 0 24 24" fill="none" stroke="#222" stroke-width="2">
                        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                     </svg>
                  </button>
               </div>
               <div class="card-img-overlay"></div>
               <div class="card-body">
                  <p class="card-text">
                     <b><%= listing.title %></b>
                     <span class="card-rating">★ 5.0</span>
                     <br> 
                     &#8377; <%= listing.price?.toLocaleString("en-IN") %> /night
                     <i class="tax-info"> &nbsp; &nbsp; +18% GST</i>
                  </p>
               </div>
            </div>
         </a>
      <% } %>
   <% } %>

</div>

<script>
   let taxSwitch = document.getElementById("flexSwitchCheckDefault");
   taxSwitch.addEventListener("click", () => {
      let taxInfo = document.getElementsByClassName("tax-info");
      for (info of taxInfo) {
         if (info.style.display != "inline") {
            info.style.display = "inline";
         } else {
            info.style.display = "none";
         }
      }
   });
</script>