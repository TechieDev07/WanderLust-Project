<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sign Up | Wanderlust</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Plus Jakarta Sans', sans-serif; }

    .page-wrapper {
      width: 100vw;
      height: 100vh;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      grid-template-rows: repeat(2, 1fr);
      gap: 8px;
      padding: 8px;
      position: relative;
    }

    .bg-tile {
      background-size: cover;
      background-position: center;
      border-radius: 12px;
      filter: brightness(0.85);
    }

    .card-overlay {
      position: absolute;
      top: 0; left: 0;
      width: 100%; height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 10;
    }

    .signup-card {
      background: white;
      border-radius: 16px;
      padding: 2rem;
      width: 100%;
      max-width: 420px;
      box-shadow: 0 8px 40px rgba(0,0,0,0.2);
      max-height: 90vh;
      overflow-y: auto;
    }

    .signup-card h2 {
      font-size: 1.4rem;
      font-weight: 700;
      margin-bottom: 1.5rem;
      text-align: center;
    }

    .signup-card .form-control {
      border-radius: 8px;
      padding: 0.75rem 1rem;
      border: 1.5px solid #ddd;
      font-size: 0.95rem;
    }

    .signup-card .form-control:focus {
      border-color: #fe424d;
      box-shadow: 0 0 0 3px rgba(254,66,77,0.12);
    }

    .btn-signup-submit {
      width: 100%;
      background: #fe424d;
      color: white;
      border: none;
      border-radius: 8px;
      padding: 0.75rem;
      font-size: 1rem;
      font-weight: 600;
      margin-top: 0.5rem;
      transition: background 0.2s;
      cursor: pointer;
    }

    .btn-signup-submit:hover { background: #e0333e; }

    .bottom-link {
      text-align: center;
      margin-top: 1rem;
      font-size: 0.9rem;
      color: #6b7280;
    }

    .bottom-link a {
      color: #fe424d;
      font-weight: 600;
      text-decoration: none;
    }

    .bottom-link a:hover { text-decoration: underline; }
  </style>
</head>
<body>

<div class="page-wrapper">
  <!-- Background tiles -->
  <div class="bg-tile" style="background-image: url('https://images.unsplash.com/photo-1520250497591-112f2f40a3f4?w=600')"></div>
  <div class="bg-tile" style="background-image: url('https://images.unsplash.com/photo-1476514525535-07fb3b4ae5f1?w=600')"></div>
  <div class="bg-tile" style="background-image: url('https://images.unsplash.com/photo-1499793983690-e29da59ef1c2?w=600')"></div>
  <div class="bg-tile" style="background-image: url('https://images.unsplash.com/photo-1504280390367-361c6d9f38f4?w=600')"></div>
  <div class="bg-tile" style="background-image: url('https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=600')"></div>
  <div class="bg-tile" style="background-image: url('https://images.unsplash.com/photo-1571003123894-1f0594d2b5d9?w=600')"></div>
  <div class="bg-tile" style="background-image: url('https://images.unsplash.com/photo-1439066615861-d1af74d74000?w=600')"></div>
  <div class="bg-tile" style="background-image: url('https://images.unsplash.com/photo-1502784444187-359ac186c5bb?w=600')"></div>

  <!-- Signup card -->
  <div class="card-overlay">
    <div class="signup-card">
      <h2>Sign up on Wanderlust</h2>
      <form action="/signup" method="POST" class="needs-validation" novalidate>
        <div class="mb-3">
          <label for="username" class="form-label">Username</label>
          <input name="username" id="username" type="text" class="form-control" placeholder="Choose a username" required />
          <div class="valid-feedback">Looks good!</div>
        </div>
        <div class="mb-3">
          <label for="email" class="form-label">Email</label>
          <input name="email" id="email" type="email" class="form-control" placeholder="Enter your email" required />
        </div>
        <div class="mb-3">
          <label for="password" class="form-label">Password</label>
          <input name="password" id="password" type="password" class="form-control" placeholder="Create a password" required />
        </div>
        <button class="btn-signup-submit">Sign Up</button>
      </form>
      <div class="bottom-link">
        Already have an account? <a href="/login">Log in</a>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>